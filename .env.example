# ═══════════════════════════════════════════════════════════════════════
# КІНО.UA — Environment Variables
#
# Для локальної розробки: скопіюйте цей файл як .env.local
# Для продакшену (Vercel): встановіть змінні в Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://kino-ua.vercel.app
NEXT_PUBLIC_APP_NAME=КІНО.UA

# ── TMDB API (сервер-сайд — ключ НЕ відображається клієнту) ────────────
#
# Як отримати:
#   1. Зареєструйтесь на https://www.themoviedb.org/signup
#   2. Профіль → Settings → API → Create → Developer
#   3. Скопіюйте "API Key (v3 auth)"
#
# ВАЖЛИВО: TMDB_API_KEY (без NEXT_PUBLIC_) зберігається тільки на сервері.
# Він ніколи не потрапляє до браузера — Next.js Server Components
# та /api/movies маршрути використовують його безпечно.
TMDB_API_KEY=

# ── TMDB API (клієнт-сайд — для ручного введення через UI) ─────────────
# Необов'язково. Якщо встановлено — дозволяє надвисокий пріоритет для
# client-side завантаження (напр. через модальне вікно налаштувань).
# Якщо не потрібно — залиште порожнім, користувач введе ключ вручну в UI.
NEXT_PUBLIC_TMDB_API_KEY=

# ── Analytics (опціонально) ─────────────────────────────────────────────
# Отримайте на https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Images ──────────────────────────────────────────────────────────────
# true = вимкнути оптимізацію (тільки для статичного / Docker хостингу)
# false = використовувати Vercel Image Optimization (рекомендовано)
NEXT_PUBLIC_IMAGE_UNOPTIMIZED=false

# ── Docker ──────────────────────────────────────────────────────────────
# Встановлюється автоматично при: npm run build:docker
DOCKER_BUILD=false
PORT=3000
DOMAIN=kino-ua.com
